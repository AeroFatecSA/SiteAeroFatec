@page
@model SiteAeroFatec.Pages.IndexModel
<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AeroFatecSA | Esquadrão de Drones</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            :root {
                --preto: #0b0b0b;
                --preto-claro: #1a1a1a;
                --vermelho: #e60000;
                --branco: #ffffff;
            }

            body {
                background-color: var(--preto);
                color: var(--branco);
                font-family: 'Inter', sans-serif;
            }

            img {
                max-width: 100%;
                height: auto;
            }

            .navbar {
                background-color: rgba(0, 0, 0, 0.95);
                border-bottom: 2px solid var(--vermelho);
            }

            .logo {
                font-weight: 800;
                letter-spacing: 1px;
            }

                .logo span {
                    color: var(--vermelho);
                }

            .hero-banner {
                background-image: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('img/Banner.png');
                background-size: cover;
                background-position: center;
                background-attachment: fixed;
                height: 100vh;
                width: 100%;
                position: relative;
                display: flex;
                align-items: center;
                justify-content: center;
                text-align: center;
            }

            .overlay {
                background: rgba(0, 0, 0, 0.6);
                width: 100%;
                height: 100%;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .conteudo-banner h1 {
                font-size: 4rem;
                font-weight: 900;
                text-shadow: 3px 3px 15px rgba(0, 0, 0, 0.8);
            }

            .btn-conheca {
                background-color: var(--vermelho);
                color: white;
                padding: 15px 40px;
                text-decoration: none;
                font-weight: bold;
                border-radius: 50px;
                transition: 0.3s;
                display: inline-block;
            }

                .btn-conheca:hover {
                    background-color: #b30000;
                    transform: scale(1.05);
                    color: white;
                }

            .historia-container {
                padding: 100px 15px;
            }

            .linha-vermelha {
                width: 60px;
                height: 4px;
                background: var(--vermelho);
                margin-bottom: 20px;
            }

            .img-fluida-estilizada {
                width: 100%;
                border-radius: 15px;
                border-right: 8px solid var(--vermelho);
                box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
            }

            .img-fluida-estilizada-invertida {
                width: 100%;
                border-radius: 15px;
                border-left: 8px solid var(--vermelho);
                box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
            }

            .setor-titulo {
                color: var(--branco);
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 2px;
            }

            .cargo-badge {
                background-color: var(--vermelho);
                color: var(--branco);
                font-size: 0.75rem;
                font-weight: bold;
                padding: 4px 12px;
                border-radius: 20px;
                display: inline-block;
                margin-bottom: 10px;
                text-transform: uppercase;
            }

            .membro-card {
                background-color: #1a1a1a;
                border-radius: 12px;
                text-align: center;
                padding: 20px 10px;
                height: 100%;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                transition: 0.3s ease;
                border: 1px solid rgba(255, 255, 255, 0.05);
            }

                .membro-card:hover {
                    transform: translateY(-5px);
                    border-color: #e60000;
                }

            .membro-img {
                width: 120px;
                height: 120px;
                border-radius: 50%;
                object-fit: cover;
                border: 3px solid #e60000;
                margin: 0 auto 15px;
            }

            .membro-info h5 {
                font-size: 1rem;
                margin-top: 10px;
                color: #ffffff;
            }

            .social-links {
                display: flex;
                justify-content: center;
                gap: 15px;
                margin-top: 10px;
                flex-wrap: wrap;
            }

                .social-links a {
                    color: #ffffff;
                    transition: 0.3s;
                    font-size: 1.1rem;
                }

                    .social-links a:hover {
                        color: #e60000;
                        transform: translateY(-3px);
                    }

            .card-contribua {
                background-color: #1a1a1a;
                border: 2px solid var(--vermelho);
                border-radius: 15px;
                transition: 0.3s;
            }

                .card-contribua:hover {
                    transform: translateY(-5px);
                    box-shadow: 0 10px 30px rgba(230, 0, 0, 0.2);
                }

            .galeria-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
                gap: 20px;
            }

            .foto-item {
                width: 100%;
                height: 250px;
                object-fit: cover;
                border-radius: 10px;
                cursor: pointer;
                transition: 0.4s;
                border: 2px solid transparent;
            }

                .foto-item:hover {
                    transform: translateY(-10px);
                    border-color: var(--vermelho);
                }

            .modal {
                display: none;
                position: fixed;
                z-index: 2000;
                background: rgba(0,0,0,0.95);
                width: 100%;
                height: 100%;
                top: 0;
                left: 0;
            }

            .modal-conteudo {
                margin: auto;
                display: block;
                max-width: 80%;
                max-height: 80%;
                margin-top: 5%;
                border: 3px solid var(--vermelho);
            }

            .fechar-modal {
                position: absolute;
                top: 20px;
                right: 40px;
                font-size: 50px;
                color: white;
                cursor: pointer;
            }

            .site-footer {
                background-color: #0b0b0b;
                color: #ffffff;
                padding: 60px 0 20px;
                border-top: 3px solid #e60000;
            }

            .logo-footer {
                font-size: 1.8rem;
                font-weight: 800;
                margin-bottom: 15px;
            }

                .logo-footer span {
                    color: #e60000;
                }

            .footer-links {
                list-style: none;
                padding: 0;
            }

                .footer-links li {
                    margin-bottom: 10px;
                }

                .footer-links a {
                    color: #ffffff;
                    text-decoration: none;
                    transition: 0.3s;
                }

                    .footer-links a:hover {
                        color: #e60000;
                        padding-left: 5px;
                    }

            .footer-divider {
                border-top: 1px solid rgba(255, 255, 255, 0.1);
                margin: 40px 0 20px;
            }

            .copyright {
                font-size: 0.85rem;
                color: #888;
            }

            @@media (max-width: 768px) {
                .conteudo-banner h1 {
                    font-size: 2.2rem;
                    text-shadow: 2px 2px 8px rgba(0,0,0,0.9);
                }

                .hero-banner {
                    background-attachment: scroll;
                }

                .historia-container {
                    padding: 50px 15px;
                }

                    .historia-container .col-md-6 {
                        text-align: center;
                        margin-bottom: 30px;
                    }

                .linha-vermelha {
                    margin: 0 auto 20px auto;
                }

                .galeria-grid {
                    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
                    gap: 10px;
                }

                .foto-item {
                    height: 180px;
                }

                .modal-conteudo {
                    max-width: 95%;
                    max-height: 90vh;
                    margin-top: 15%;
                }

                .fechar-modal {
                    top: 10px;
                    right: 20px;
                    font-size: 40px;
                }

                .site-footer {
                    text-align: center;
                }

                .membro-img {
                    width: 90px;
                    height: 90px;
                }
            }
    </style>
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand logo" href="#">Aero<span>Fatec</span>SA</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="#home">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="#historia">História</a></li>
                    <li class="nav-item"><a class="nav-link" href="#galeria">Galeria</a></li>
                    <li class="nav-item"><a class="nav-link" href="#membros">Equipe</a></li>
                    <li class="nav-item"><a class="nav-link text-danger fw-bold" href="#contribua">Contribua</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <header id="home" class="hero-banner">
        <div class="overlay">
            <div class="conteudo-banner">
                <h1>PROJETANDO O AMANHÃ,<br>VOANDO HOJE.</h1>
                <p>A tecnologia elevada a potência máxima pela FATEC Santo André.</p>
                <a href="#historia" class="btn-conheca">Conheça a Equipe</a>
            </div>
        </div>
    </header>

    <section id="historia" class="historia-container container">
        <div class="row align-items-center mb-5">
            <div class="col-md-6 texto-coluna">
                <h2>Nossa História</h2>
                <div class="linha-vermelha"></div>
                <p>
                    Fundada em 2026, a nossa equipe de drones da FATEC Santo André é um núcleo de inovação
                    composto por estudantes talentosos e orientação docente especializada. Unimos o conhecimento
                    acadêmico das áreas de Sistemas Embarcados, Mecânica, Computação e Automação para projetar
                    aeronaves não tripuladas de alto desempenho.
                </p>
            </div>
            <div class="col-md-6 imagem-coluna">
                <img src="img/foto1.jpg" alt="História 1" class="img-fluida-estilizada">
            </div>
        </div>
    </section>

    <section id="membros" class="container my-5 pt-5">
        <h2 class="text-center mb-5">Nossa Equipe</h2>

        @foreach (var setor in Model.EquipeCompleta.GroupBy(m => m.Setor))
        {
            <h3 class="setor-titulo text-center mt-5">@setor.Key</h3>
            <div class="linha-vermelha mx-auto mb-4"></div>

            <div class="row g-4 justify-content-center mb-5">
                @foreach (var membro in setor)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="membro-card">
                            <div class="membro-img-container">
                                <img src="@membro.Foto" alt="@membro.Nome" class="membro-img">
                            </div>

                            <div class="membro-info">
                                <h5>@membro.Nome</h5>
                                <span class="cargo-badge">@membro.Cargo</span>

                                <div class="social-links mt-2">
                                    @if (!string.IsNullOrWhiteSpace(membro.LinkLinkedIn) && membro.LinkLinkedIn != "#")
                                    {
                                        <a href="@membro.LinkLinkedIn" target="_blank" title="LinkedIn">
                                            <i class="fab fa-linkedin"></i>
                                        </a>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(membro.LinkGithub) && membro.LinkGithub != "#")
                                    {
                                        <a href="@membro.LinkGithub" target="_blank" title="GitHub">
                                            <i class="fab fa-github"></i>
                                        </a>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(membro.LinkCurriculo) && membro.LinkCurriculo != "#")
                                    {
                                        <a href="@membro.LinkCurriculo" target="_blank" title="Baixar Currículo (PDF)">
                                            <i class="fas fa-file-pdf"></i>
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <section id="contribua" class="container my-5 py-5 text-center">
        <h2 class="mb-3">Apoie o Nosso Projeto</h2>
        <div class="linha-vermelha mx-auto mb-4"></div>
        <p class="lead mb-5 mx-auto" style="max-width: 800px;">
            A inovação ganha asas quando voamos juntos. Doe você também para a vaquinha
            <strong>Aero Fatec - Montagem de Drone</strong>. Sua contribuição é fundamental para
            tirarmos nossos projetos do papel, adquirirmos peças de alta tecnologia e representarmos a nossa FATEC!
        </p>

        <div class="row justify-content-center g-4">
            <div class="col-md-5">
                <div class="card-contribua p-4 h-100 d-flex flex-column justify-content-center align-items-center">
                    <i class="fab fa-pix fa-3x mb-3" style="color: #32BCAD;"></i>
                    <h4>Transferência PIX</h4>
                    <p class="mt-2 mb-3">Transfira de forma rápida e direta usando a nossa chave PIX da Vakinha:</p>
                    <h5 class="fw-bold p-2 bg-dark rounded user-select-all w-100 text-danger border border-secondary">
                        5999436@vakinha.com.br
                    </h5>
                    <small class="text-muted mt-2">(Copie a chave acima no seu app de banco)</small>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card-contribua p-4 h-100 d-flex flex-column justify-content-center align-items-center">
                    <i class="fas fa-hand-holding-heart fa-3x mb-3 text-danger"></i>
                    <h4>Site do Vakinha</h4>
                    <p class="mt-2 mb-4">Conheça mais detalhes da nossa campanha, veja nossa meta e doe pelo site oficial:</p>
                    <a href="https://vaka.me/5999436?utm_campaign=whatsapp&utm_medium=website&utm_content=5999436&utm_source=social-shares" target="_blank" class="btn btn-danger mt-auto rounded-pill px-5 py-2 fw-bold w-100 text-uppercase">
                        Acessar Vakinha
                    </a>
                </div>
            </div>
        </div>
    </section>

    <footer class="site-footer">
        <div class="container text-center text-md-start">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <div class="logo-footer">Aero<span>Fatec</span>SA</div>
                    <p>Inovação e tecnologia em sistemas aéreos não tripulados.</p>
                </div>

                <div class="col-md-4 mb-4">
                    <h5>Links Rápidos</h5>
                    <ul class="footer-links list-unstyled">
                        <li><a href="#home">Home</a></li>
                        <li><a href="#historia">História</a></li>
                        <li><a href="#membros">Equipe</a></li>
                        <li><a href="#contribua">Apoie Nosso Projeto</a></li>
                    </ul>
                </div>

                <div class="col-md-4">
                    <h5>Instituição</h5>
                    <p>FATEC Santo André</p>
                    <p>R. Pref. Justino Paixão, 150 - Vila Bastos</p>
                    <p>Santo André - SP</p>

                    <h5 class="mt-4">Nossas Redes</h5>
                    <div class="social-links justify-content-center justify-content-md-start">
                        <a href="https://www.linkedin.com/in/drones-fatec-6a03993b6?utm_source=share_via&utm_content=profile&utm_medium=member_ios" target="_blank" title="LinkedIn da AeroFatecSA"><i class="fab fa-linkedin fa-lg"></i></a>
                        <a href="https://www.instagram.com/aerofatec?igsh=MWxkZXk0bHEwdDE0MQ%3D%3D&utm_source=qr" target="_blank" title="Instagram da AeroFatecSA"><i class="fab fa-instagram fa-lg"></i></a>
                        <a href="https://youtube.com/@@aerofatec?si=4Gb0hbv6cQ8NHQgM" target="_blank" title="YouTube da AeroFatecSA"><i class="fab fa-youtube fa-lg"></i></a>
                    </div>
                </div>
            </div>

            <hr class="footer-divider">
            <p class="text-center copyright">&copy; 2026 AeroFatecSA.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>